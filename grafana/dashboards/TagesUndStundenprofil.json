          "editorMode": "code",
          "format": "table",
          "hide": true,
          "rawQuery": true,
          "rawSql": "SELECT\r\n  DATE(CONVERT_TZ(FROM_UNIXTIME(previous_timestamp), 'UTC', 'Europe/Berlin')) AS tag,  -- Kalendertag (lokale Zeit)\r\n  SUM(grid) AS kWh\r\nFROM (\r\n  SELECT\r\n    (CAST(meter_value AS SIGNED) -\r\n     CAST(LAG(meter_value) OVER (PARTITION BY id ORDER BY timestamp_client) AS SIGNED)) / 10000 AS grid,\r\n    LAG(timestamp_client) OVER (PARTITION BY id ORDER BY timestamp_client) AS previous_timestamp\r\n  FROM sml_v1\r\n  WHERE\r\n    id = \"$id\"\r\n    AND $__unixEpochFilter(timestamp_client)\r\n) AS sub\r\nWHERE grid IS NOT NULL\r\nGROUP BY tag\r\nORDER BY tag;",

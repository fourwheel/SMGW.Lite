      "targets": [
        {
          "dataset": "hz_v1",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_HZ-V1}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  -- '+00:00' ist UTC, '+01:00' ist Berlin Winterzeit (nutze '+02:00' für Sommerzeit)\r\n  LPAD(HOUR(CONVERT_TZ(FROM_UNIXTIME(previous_timestamp), '+00:00', '+02:00')), 2, '0') AS hour_of_day,\r\n  SUM(grid) AS Wh,\r\n  ROUND(SUM(grid) * 100.0 / SUM(SUM(grid)) OVER (), 2) AS Percentage\r\n\r\nFROM (\r\n  SELECT\r\n    (CAST(meter_value AS SIGNED) -\r\n     CAST(LAG(meter_value) OVER (PARTITION BY id ORDER BY timestamp_client) AS SIGNED)) / 10 AS grid,\r\n    LAG(timestamp_client) OVER (PARTITION BY id ORDER BY timestamp_client) AS previous_timestamp\r\n  FROM `hz-v1`.`sml_v1`  -- Backticks für DB-Namen mit Bindestrich\r\n  WHERE\r\n    id = '$id'\r\n    AND $__unixEpochFilter(timestamp_client)\r\n) AS sub\r\nWHERE grid IS NOT NULL\r\nGROUP BY hour_of_day\r\nORDER BY hour_of_day;",
          "refId": "vorheriger Zeitstempel",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        },
        {
          "dataset": "hz_v1",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_HZ-V1}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": true,
          "rawQuery": true,
          "rawSql": "SELECT\r\n  LPAD(HOUR(CONVERT_TZ(FROM_UNIXTIME(previous_timestamp), 'UTC', 'Europe/Berlin')), 2, '0') AS hour_of_day,  -- Stunde als String mit führender Null\r\n  SUM(grid) AS Wh,\r\n  ROUND(SUM(grid) * 100.0 / SUM(SUM(grid)) OVER (), 2) AS Percentage  -- Prozentanteil, gerundet auf 2 Nachkommastellen\r\n\r\nFROM (\r\n  SELECT\r\n    (CAST(meter_value AS SIGNED) -\r\n     CAST(LAG(meter_value) OVER (PARTITION BY id ORDER BY timestamp_client) AS SIGNED)) / 10 AS grid,\r\n    LAG(timestamp_client) OVER (PARTITION BY id ORDER BY timestamp_client) AS previous_timestamp  -- Vorheriger Zeitstempel\r\n  FROM sml_v1\r\n  WHERE\r\n    id = \"$id\"\r\n    AND $__unixEpochFilter(timestamp_client)\r\n) AS sub\r\nWHERE grid IS NOT NULL\r\nGROUP BY hour_of_day\r\nORDER BY hour_of_day;",
          "refId": "A",

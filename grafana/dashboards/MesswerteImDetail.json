      "targets": [
        {
          "dataset": "hz-v1",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH verbrauch AS (\r\n  SELECT\r\n    timestamp_client AS ts,\r\n    meter_value / 10 AS wh,\r\n    LAG(meter_value / 10) OVER (ORDER BY timestamp_client) AS wh_prev,\r\n    LAG(timestamp_client)  OVER (ORDER BY timestamp_client) AS ts_prev\r\n  FROM sml_v1\r\n  WHERE id = \"$id\"\r\n    AND timestamp_client BETWEEN $__unixEpochFrom() AND $__unixEpochTo()\r\n),\r\ndeltas AS (\r\n  SELECT\r\n    ts,\r\n    (wh - wh_prev) AS delta_wh\r\n  FROM verbrauch\r\n  WHERE wh_prev IS NOT NULL\r\n    AND (wh - wh_prev) >= 0\r\n),\r\ngesamt_kwh AS (\r\n  SELECT SUM(delta_wh) / 1000 AS total_kwh FROM deltas\r\n),\r\nco2_weighted AS (\r\n  SELECT SUM(\r\n    d.delta_wh / 1000 *\r\n    c.value\r\n  ) AS co2_gramm\r\n  FROM deltas d\r\n  JOIN co2_intensity_hourly c\r\n    ON c.zone = 'DE_LU'\r\n    AND c.emission_type = 'Operational'\r\n    AND c.forecast_type = 'Actual'\r\n    AND c.ts_utc = DATE_FORMAT(FROM_UNIXTIME(d.ts), '%Y-%m-%d %H:00:00')\r\n),\r\npreis_weighted AS (\r\n  SELECT SUM(\r\n    d.delta_wh / 1000 *\r\n    (p.price_eur_mwh / 1000)\r\n  ) AS kosten_eur\r\n  FROM deltas d\r\n  JOIN power_prices p\r\n    ON p.bidding_zone = 'DE-LU'\r\n    AND p.unix_timestamp = (\r\n      FLOOR(d.ts / 900) * 900\r\n    )\r\n)\r\nSELECT\r\n  gesamt_kwh.total_kwh                                        AS \"Verbrauch (kWh)\"\r\nFROM gesamt_kwh, co2_weighted, preis_weighted;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Verbrauch",
      "type": "stat"

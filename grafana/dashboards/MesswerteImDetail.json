          "editorMode": "code",
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT \n\n\n  (\n    (\n      (3600 / 10 * (\n        (SELECT meter_value FROM sml_v1 WHERE id = \"$id\" AND timestamp_client <= $__unixEpochTo() ORDER BY timestamp_client DESC LIMIT 1) - \n        (SELECT meter_value FROM sml_v1 WHERE id = \"$id\" AND timestamp_client >= $__unixEpochFrom() ORDER BY timestamp_client ASC LIMIT 1)\n      )) \n      / \n      (\n        (SELECT timestamp_client FROM sml_v1 WHERE id = \"$id\" AND timestamp_client <= $__unixEpochTo() ORDER BY timestamp_client DESC LIMIT 1) - \n        (SELECT timestamp_client FROM sml_v1 WHERE id = \"$id\" AND timestamp_client >= $__unixEpochFrom() ORDER BY timestamp_client ASC LIMIT 1)\n      )\n    ) * 8760\n  ) AS Jahresenergie_kWh\n",

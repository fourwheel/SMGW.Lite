<?php

$_db_host      = "localhost";
$_db_username  = "YOUR_DB_USER";
$_db_passwort  = "YOUR_DB_PASSWORD";
$_db_datenbank = "YOUR_DB_NAME";

$_link = mysqli_connect($_db_host, $_db_username, $_db_passwort);

if (!$_link) {
    http_response_code(501);
    die("Database connection failed: " . mysqli_error());
}

mysqli_select_db($_link, $_db_datenbank);
